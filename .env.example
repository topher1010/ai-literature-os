# ai-literature-os — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env. The included pre-commit hook blocks common secrets.

# === Required ===

# Where your vault of paper markdown files lives.
VAULT_DIR=

# Where source PDFs (and DOCX, if you use the Endnote path) live.
# Read-only as far as the pipeline is concerned.
SOURCE_DIR=

# Where derived navigation artifacts go (index, topic clusters, sidecars).
# Must be OUTSIDE VAULT_DIR. Anything inside VAULT_DIR gets embedded by QMD.
NAV_DIR=

# OpenRouter API key — used for embeddings (currently google/gemini-embedding-2-preview)
# and as a routing fallback for Claude.
OPENROUTER_API_KEY=

# Anthropic API key — used by Claude Code skills and pipeline LLM calls.
ANTHROPIC_API_KEY=

# === Optional — Supabase integration for the research digest ===

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# === Optional — research digest fail-closed scoring thresholds ===
# Pipeline aborts BEFORE writing to Supabase if scoring or summary failure
# rate exceeds these. Defaults: 50 (each). Tighten after you have ~4 weeks
# of run-report data showing what normal failure rates look like.
DIGEST_SCORING_ABORT_THRESHOLD_PCT=50
DIGEST_SUMMARY_ABORT_THRESHOLD_PCT=50

# === Optional — paths ===

# Path to your Claude Code CLI binary. Required for cron-invoked LLM calls
# (cron has no PATH). Find with: command -v claude
CLAUDE_BIN=

# Where the PaperQA2 index lives. Default: $NAV_DIR/paperqa-index/
PQA_INDEX_DIR=

# Where pipeline scripts write logs. Default: /tmp
LOG_DIR=

# Email for Unpawall API (open-access full-text lookups). Required by their ToS.
UNPAYWALL_EMAIL=

# Acknowledgement env var for QMD's vec0 store. Set to 1 ONLY when you are
# intentionally migrating to a new embedding model with a different vector
# dimension and accept that vec0 will be wiped. The patched store.ts refuses
# to drop a populated vec0 table without this acknowledgement — this prevents
# a misconfigured embed run from silently destroying the vector store.
# QMD_ALLOW_VEC_RECREATE=

# === Optional — researcher profile for digest scoring ===
# A one-line description of who you are and what you study. Used to seed the
# Claude scoring prompt in the research digest. Example:
# "vascular biologist studying endothelial dysfunction in metabolic disease"
RESEARCHER_PROFILE=
